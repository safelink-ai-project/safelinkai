{
  "manifest_version": 3,
  "name": "SafeLink AI Scanner",
  "version": "1.0",
  "description": "Scan URLs for phishing and malicious activity",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "permissions": ["activeTab", "scripting"]
}